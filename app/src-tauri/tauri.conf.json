{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MD Editor",
  "version": "1.0.0",
  "identifier": "com-md-editor-app",
  "build": {
    "frontendDist": "../web",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npx vite web --port 5173 --strictPort",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MD Editor",
        "decorations": false,
        "width": 1100,
        "height": 720,
        "resizable": true,
        "center": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/Square30x30Logo.png",
      "icons/Square70x70Logo.png",
      "icons/Square150x150Logo.png",
      "icons/StoreLogo.png"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown 文档",
        "role": "Editor"
      }
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["SimpChinese", "English"],
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["md-editor"]
      }
    }
  }
}
